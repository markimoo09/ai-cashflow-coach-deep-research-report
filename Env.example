# Env.example
# Copy this file to Env.local (git-ignored) and fill in your values.
# The app boots safely with all keys empty — analytics and purchases are
# no-ops until production credentials are provided.

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Obtain from https://app.revenuecat.com → Project settings → API keys
REVENUECAT_PUBLIC_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostHog ──────────────────────────────────────────────────────────────────
# Obtain from https://app.posthog.com → Project settings → API keys
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://app.posthog.com

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
